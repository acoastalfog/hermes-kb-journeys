          },
          "cursor_id": {
            "description": "Guided KB Review Session cursor id from the preview lease.",
            "type": "string"
          },
          "decision": {
            "description": "Proposal decision to apply.",
            "enum": [
              "approve",
              "reject",
              "archive",
              "skip",
