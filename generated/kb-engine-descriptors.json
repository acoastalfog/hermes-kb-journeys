              "demote",
              "duplicate",
              "supersede",
              "reroute"
            ],
            "type": "string"
          },
          "decision_scope": {
            "description": "Explicit scope confirmed by the preview lease.",
            "enum": [
              "explicit_ids",
              "all_viewed",
              "all_window",
              "all_filtered"
