      "description": "Apply the same confirmed review inbox decision to a batch of proposals through one previewed confirmed-control envelope.",
      "input_schema": {
        "additionalProperties": false,
        "properties": {
          "actor": {
            "description": "Human or agent actor requesting the confirmed write.",
