            },
            "type": "array"
          },
          "review_session_id": {
            "description": "Guided KB Review Session id from the preview lease.",
            "type": "string"
          },
          "session_id": {
            "description": "Stable harness session id for idempotency provenance.",
            "type": "string"
          },
          "source": {
            "description": "Harness or channel provenance, such as Hermes / Telegram.",
            "type": "string"
          },
          "stop_on_error": {
            "description": "Stop confirmed execution after the first error.",
            "type": "boolean"
          },
          "user_confirmation": {
            "additionalProperties": true,
            "description": "Explicit confirmation payload with confirmed=true.",
            "type": "object"
          }
        },
        "required": [
          "proposal_ids",
          "decision",
          "actor",
          "source",
          "session_id",
          "user_confirmation"
        ],
        "type": "object"
      },
